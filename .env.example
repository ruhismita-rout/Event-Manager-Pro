# Copy this file to .env in the workspace root before running the app.
# Required for API + DB:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventflow

# Optional overrides:
# PORT=3001
# LOG_LEVEL=info
# APP_BASE_URL=http://localhost:3001
# Required for email notifications:
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=EventFlow <onboarding@resend.dev>
# NOTIFICATION_TOKEN_SECRET=change-me
# REMINDER_CRON_SECRET=optional-secret-for-reminder-endpoint
# API_BASE_URL=http://localhost:3001

# Frontend-only optional settings:
# BASE_PATH=/
# VITE_API_BASE_URL=http://localhost:3001
# VITE_API_PROXY_TARGET=http://localhost:3001
